# =============================================================
# KatalogAI — Production Environment (bereketfide.com/katalog)
# =============================================================

# ── Backend (.env) ──────────────────────────────────────────────
NODE_ENV=production
PORT=8083

# Veritabani (katalog_creator DB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=katalog_creator
DB_USER=app
DB_PASSWORD=CHANGE_ME
DB_ROOT_USER=app
DB_ROOT_PASSWORD=CHANGE_ME

# Auth
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET_RANDOM_STRING

# URL'ler
PUBLIC_URL=https://www.bereketfide.com/katalog
FRONTEND_URL=https://www.bereketfide.com/katalog
PUBLIC_API_BASE=https://www.bereketfide.com/katalog

# CORS
CORS_ORIGIN=https://www.bereketfide.com,https://bereketfide.com

# Storage
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/www/wwwroot/katalogAI/backend/uploads
LOCAL_STORAGE_BASE_URL=/katalog/uploads

# Cloudinary (opsiyonel)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=katalogai

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
MAIL_FROM=KatalogAI <noreply@bereketfide.com>

# Product Sources
SOURCE_ENCRYPTION_KEY=CHANGE_ME_32_CHARS

# Bereket Fide DB (ayni sunucu)
SOURCE_BEREKETFIDE_DB_HOST=127.0.0.1
SOURCE_BEREKETFIDE_DB_PORT=3306
SOURCE_BEREKETFIDE_DB_NAME=bereketfide
SOURCE_BEREKETFIDE_DB_USER=app
SOURCE_BEREKETFIDE_DB_PASSWORD=CHANGE_ME

# Vista Seed DB (ayni sunucu)
SOURCE_VISTASEED_DB_HOST=127.0.0.1
SOURCE_VISTASEED_DB_PORT=3306
SOURCE_VISTASEED_DB_NAME=vistaseed
SOURCE_VISTASEED_DB_USER=app
SOURCE_VISTASEED_DB_PASSWORD=CHANGE_ME

# AI
GROQ_API_KEY=CHANGE_ME

# Admin
SEED_ADMIN_EMAIL=admin@bereketfide.com
SEED_ADMIN_PASSWORD=CHANGE_ME
ALLOW_TEMP_LOGIN=0

# ── Admin Panel (.env.local) ────────────────────────────────────
# NEXT_PUBLIC_BASE_PATH=/katalog
# NEXT_PUBLIC_API_URL=https://www.bereketfide.com/katalog/api
# PANEL_API_URL=http://127.0.0.1:8083
