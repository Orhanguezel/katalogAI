# KatalogAI — Production Environment
# Bu dosyayi backend/.env olarak kopyalayip degerlerini doldur

# Genel
NODE_ENV=production
PORT=8078

# Veritabani
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=katalog_creator
DB_USER=katalogai_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Auth
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET_RANDOM_STRING

# URL'ler (domain'ine gore degistir)
PUBLIC_URL=https://katalogai.com
FRONTEND_URL=https://katalogai.com
PUBLIC_API_BASE=https://katalogai.com

# CORS
CORS_ORIGIN=https://katalogai.com

# Storage — Cloudinary (production icin onerilen)
STORAGE_DRIVER=cloudinary
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME
CLOUDINARY_FOLDER=katalogai

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=CHANGE_ME@gmail.com
SMTP_PASS=CHANGE_ME_APP_PASSWORD
MAIL_FROM=KatalogAI <noreply@katalogai.com>

# Product Sources sifreleme
SOURCE_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_RANDOM_STRING!

# AI — Groq
GROQ_API_KEY=CHANGE_ME_GROQ_API_KEY

# Admin seed
SEED_ADMIN_EMAIL=admin@katalogai.com
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Gelistirme modlari (production'da kapat)
ALLOW_TEMP_LOGIN=0
